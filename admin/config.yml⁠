backend:
  name: github
  repo: "hoor-studio/hoor-studio-web" # Aapka shop name 'Hoor Studio' ka username aur repo yahan set kar diya hai
  branch: main

media_folder: "assets/images"
public_folder: "/assets/images"

collections:
  - name: "products"
    label: "Products"
    folder: "_data/products"
    create: true
    slug: "{{slug}}"
    fields:
      - { label: "Title", name: "title", widget: "string" }
      - { label: "Category", name: "category", widget: "string", default: "Baby Garments" }
      - { label: "Price", name: "price", widget: "string" }
      - { label: "Old Price (Optional)", name: "old_price", widget: "string", required: false }
      - { label: "Description", name: "description", widget: "text" }
      - { label: "Badge (Optional)", name: "badge", widget: "select", options: ["none", "sale", "hot"], default: "none" }
      - label: "Product Gallery (Multiple Images)"
        name: "gallery"
        widget: "list"
        summary: "{{fields.image}}"
        field: { label: "Image", name: "image", widget: "image" }
